{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.lib.tsbuildinfo",
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@api/*": ["src/services/api/*"],
      "@popup/*": ["src/services/popup/*"],
      "@storage/*": ["src/services/storage/*"],
      "@services/*": ["src/services/*"],
      "@i18n/*": ["src/i18n/*"]
    },

    /* Linting - Keeping strict checks but excluding problematic libraries */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitAny": false,           // Temporarily disabled for library compatibility
    "noImplicitThis": false,          // Temporarily disabled for library compatibility
    "strictNullChecks": false,        // Temporarily disabled for library compatibility
    "strictFunctionTypes": false,     // Temporarily disabled for library compatibility
    "noUncheckedIndexedAccess": false, // Temporarily disabled for library compatibility
    "exactOptionalPropertyTypes": false, // Temporarily disabled for library compatibility
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "erasableSyntaxOnly": false,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "include": [
    "src/**/*.ts", 
    "src/**/*.tsx", 
    "src/**/*.vue", 
    "src/**/*.d.ts"
  ],
  "exclude": [
    "node_modules/**/*",
    "**/node_modules/katex/**/*"
  ]
}